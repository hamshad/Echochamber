# Echochamber environment example
# Copy this file to `.env` and fill values, or set the following on your deployment (Vercel) as environment variables.

# Option A (recommended for Vercel): Paste the entire service account JSON as a single-line string
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Option B (recommended for local development): Point to a local service account JSON file
FIREBASE_SERVICE_ACCOUNT_PATH=./rnfirebase-c3268-firebase-adminsdk-fbsvc-88d53a8ddb.json

# Firebase Storage bucket name (required)
FIREBASE_STORAGE_BUCKET=rnfirebase-c3268.firebasestorage.app

# Firebase Realtime Database URL (required)
FIREBASE_DATABASE_URL=https://rnfirebase-c3268-default-rtdb.firebaseio.com

# Optional: TTL in milliseconds (default: 1 hour)
# TTL_MS=3600000

# Optional: Cleanup interval in milliseconds (default: 60 seconds)
# CLEANUP_INTERVAL_MS=60000

# Optional: Port to run the server on (default: 3000)
# PORT=3000

# Notes:
# - .env is ignored by git (see .gitignore). Do NOT commit your service account key to source control.
# - For Vercel, set FIREBASE_SERVICE_ACCOUNT to the full JSON string in Project Settings → Environment Variables.
# - For local development, place the service account JSON file at the path referenced by FIREBASE_SERVICE_ACCOUNT_PATH.
# - All other variables are optional and will use sensible defaults if omitted.

# Vercel-specific Environment Variables (optional, Vercel sets these by default)
# NODE_ENV=production
# VERCEL=1